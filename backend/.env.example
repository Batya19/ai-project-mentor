APP_NAME=AI Project Mentor API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/ai_project_mentor
JWT_SECRET_KEY=replace_with_a_long_random_secret_32_plus_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Get a free Groq API key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
